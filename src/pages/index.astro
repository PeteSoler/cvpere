---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- HERO -->
		<section class="hero">
			<div class="hero-bg-orb orb1"></div>
			<div class="hero-bg-orb orb2"></div>
			<div class="hero-inner">
				<div class="hero-text">
					<div class="badge-available">
						<span class="dot"></span> Available for new opportunities
					</div>
					<h1>Pere<br /><span class="gradient-text">Soler</span></h1>
					<p class="subtitle">Full-Stack Software Developer</p>
					<p class="tagline">Frontend · Backend · API Design · Web Applications</p>
					<div class="hero-meta">
						<span>
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
							Catalonia, Spain
						</span>
						<a href="mailto:peree.sooler@gmail.com">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							peree.sooler@gmail.com
						</a>
						<a href="https://linkedin.com/in/peresolerrigau" target="_blank" rel="noopener">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
							LinkedIn
						</a>
					</div>
					<div class="hero-actions">
						<a href="#experience" class="btn-primary">View Experience</a>
						<a href="mailto:peree.sooler@gmail.com" class="btn-ghost">Get in Touch</a>
					</div>
				</div>
				<div class="hero-photo-wrap">
					<div class="photo-ring">
						<img src="/avatar.jpg" alt="Pere Soler" class="avatar" />
					</div>
					<div class="photo-glow"></div>
				</div>
			</div>
		</section>

		<!-- SUMMARY -->
		<section class="section summary-section">
			<div class="container">
				<p class="eyebrow">About me</p>
				<p class="summary">
					Full-Stack Developer with hands-on experience building <strong>web applications end-to-end</strong> —
					from crafting responsive, user-facing interfaces to designing and shipping robust
					<strong>RESTful APIs and backend services</strong> in C# and .NET. I care deeply about
					clean architecture, SOLID principles, and writing code that's as maintainable as it is performant.
					Whether it's wiring up a React front-end, architecting a database schema, or automating workflows
					through scripting and APIs, I bring a <strong>full-stack mindset</strong> to every project.
				</p>
			</div>
		</section>

		<!-- EXPERIENCE -->
		<section id="experience" class="section">
			<div class="container">
				<p class="eyebrow">Career</p>
				<h2 class="section-title">Experience</h2>

				<div class="timeline">
					<article class="job">
						<div class="job-accent"></div>
						<div class="job-body">
							<div class="job-header">
								<div>
									<h3 class="company">Concentrix</h3>
									<p class="role">Support Engineer — Security &amp; Compliance</p>
								</div>
								<div class="job-meta">
									<span class="period">2025 – Present</span>
									<span class="location">Remote</span>
								</div>
							</div>
							<ul>
								<li>Automated administrative tasks and compliance data reports using PowerShell scripting, reducing manual effort across daily security operations.</li>
								<li>Integrated with Microsoft Graph API to manage enterprise identities, permissions, and access controls at scale.</li>
								<li>Provided technical expertise in Microsoft Purview and Microsoft 365 security frameworks, supporting governance and regulatory alignment.</li>
								<li>Debugged and remediated compliance policies and information governance configurations.</li>
							</ul>
							<div class="tags">
								<span>PowerShell</span><span>Microsoft Graph API</span><span>Microsoft Purview</span><span>Microsoft 365</span>
							</div>
						</div>
					</article>

					<article class="job">
						<div class="job-accent"></div>
						<div class="job-body">
							<div class="job-header">
								<div>
									<h3 class="company">Vueling Airlines / Vueling University</h3>
									<p class="role">Backend .NET Developer</p>
								</div>
								<div class="job-meta">
									<span class="period">Late 2024</span>
									<span class="location">Viladecans, Spain</span>
								</div>
							</div>
							<ul>
								<li>Developed high-performance WebAPIs using .NET Core and C# in a fast-paced airline tech environment.</li>
								<li>Applied SOLID design principles to deliver maintainable, scalable backend services.</li>
								<li>Utilized Entity Framework for database abstraction and ORM management.</li>
								<li>Implemented Unit Testing with xUnit/NUnit and Moq to enforce code quality standards.</li>
							</ul>
							<div class="tags">
								<span>.NET Core</span><span>C#</span><span>Entity Framework</span><span>xUnit</span><span>NUnit</span><span>Moq</span>
							</div>
						</div>
					</article>

					<article class="job">
						<div class="job-accent"></div>
						<div class="job-body">
							<div class="job-header">
								<div>
									<h3 class="company">Garoina Comunicació</h3>
									<p class="role">Software Programmer</p>
								</div>
								<div class="job-meta">
									<span class="period">2023 – 2024</span>
									<span class="location">Platja d'Aro, Spain</span>
								</div>
							</div>
							<ul>
								<li>Developed and maintained full-stack applications with PHP, C#, and Angular across multiple client projects.</li>
								<li>Designed and optimized relational databases using SQL Server (SSMS) and MySQL.</li>
								<li>Documented and tested APIs using Swagger/OpenAPI, improving frontend-backend integration workflows.</li>
								<li>Managed version control and CI/CD pipelines via GitHub.</li>
							</ul>
							<div class="tags">
								<span>PHP</span><span>C#</span><span>Angular</span><span>SQL Server</span><span>MySQL</span><span>Swagger</span><span>CI/CD</span>
							</div>
						</div>
					</article>

					<article class="job">
						<div class="job-accent"></div>
						<div class="job-body">
							<div class="job-header">
								<div>
									<h3 class="company">Cóndor Aretex SA</h3>
									<p class="role">IT Programmer &amp; Help Desk</p>
								</div>
								<div class="job-meta">
									<span class="period">Early 2022</span>
									<span class="location">Arenys de Mar, Spain</span>
								</div>
							</div>
							<ul>
								<li>Built internal automation tools in Java and maintained legacy systems in COBOL.</li>
								<li>Provided technical troubleshooting and hardware/software support for company staff.</li>
							</ul>
							<div class="tags">
								<span>Java</span><span>COBOL</span><span>Help Desk</span>
							</div>
						</div>
					</article>
				</div>
			</div>
		</section>

		<!-- SKILLS -->
		<section id="skills" class="section skills-section">
			<div class="container">
				<p class="eyebrow">What I work with</p>
				<h2 class="section-title">Technical Skills</h2>
				<div class="skills-grid">
					<div class="skill-group">
						<div class="skill-icon">⚙️</div>
						<h4>Backend &amp; APIs</h4>
						<div class="skill-tags">
							<span>.NET Core</span><span>C#</span><span>ASP.NET MVC</span><span>ASP.NET Core</span>
							<span>Microsoft Graph API</span><span>REST</span><span>Swagger / OpenAPI</span>
						</div>
					</div>
					<div class="skill-group">
						<div class="skill-icon">🗄️</div>
						<h4>Databases &amp; ORM</h4>
						<div class="skill-tags">
							<span>SQL Server (SSMS)</span><span>MySQL</span><span>Entity Framework</span><span>Data Modeling</span>
						</div>
					</div>
					<div class="skill-group">
						<div class="skill-icon">🚀</div>
						<h4>Automation &amp; DevOps</h4>
						<div class="skill-tags">
							<span>PowerShell</span><span>GitHub</span><span>CI/CD</span>
							<span>xUnit</span><span>NUnit</span><span>Moq</span>
						</div>
					</div>
					<div class="skill-group">
						<div class="skill-icon">☁️</div>
						<h4>Cloud &amp; Security</h4>
						<div class="skill-tags">
							<span>Microsoft 365</span><span>Microsoft Purview</span>
							<span>Security &amp; Compliance</span><span>Azure (basic)</span>
						</div>
					</div>
					<div class="skill-group">
						<div class="skill-icon">💻</div>
						<h4>Languages</h4>
						<div class="skill-tags">
							<span>C#</span><span>PHP</span><span>Java</span><span>JavaScript</span><span>COBOL</span><span>SQL</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- EDUCATION -->
		<section id="education" class="section">
			<div class="container">
				<p class="eyebrow">Background</p>
				<h2 class="section-title">Education &amp; Languages</h2>
				<div class="edu-grid">
					<div class="edu-card">
						<div class="edu-year">2020</div>
						<h3>Desarrollo de Aplicaciones Multiplataforma</h3>
						<p>Escola Pia, Mataró</p>
					</div>
					<div class="edu-card">
						<div class="edu-year">2014</div>
						<h3>Sistemas Microinformáticos y Redes</h3>
						<p>Escola Pia, Mataró</p>
					</div>
				</div>
				<div class="languages">
					<h3>Languages</h3>
					<div class="lang-list">
						<div class="lang-item">
							<span class="lang-name">Catalan</span>
							<span class="lang-level native">Native</span>
						</div>
						<div class="lang-item">
							<span class="lang-name">Spanish</span>
							<span class="lang-level c2">C2</span>
						</div>
						<div class="lang-item">
							<span class="lang-name">English</span>
							<span class="lang-level c1">C1 — Cambridge Proficiency</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
	/* ── HERO ── */
	.hero {
		position: relative;
		overflow: hidden;
		padding: 6em 2em 5em;
		background: var(--bg);
	}
	.hero-bg-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.25;
		pointer-events: none;
	}
	[data-theme="dark"] .hero-bg-orb { opacity: 0.18; }
	.orb1 {
		width: 600px; height: 600px;
		background: radial-gradient(circle, var(--accent), transparent 70%);
		top: -200px; left: -150px;
	}
	.orb2 {
		width: 500px; height: 500px;
		background: radial-gradient(circle, var(--accent2), transparent 70%);
		bottom: -150px; right: -100px;
	}
	.hero-inner {
		position: relative;
		max-width: 1080px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 4em;
	}
	.hero-text { flex: 1; }

	.badge-available {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.3em 1em;
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 1.25em;
	}
	.dot {
		width: 8px; height: 8px;
		border-radius: 50%;
		background: #22c55e;
		box-shadow: 0 0 0 3px rgba(34,197,94,0.25);
		animation: pulse 2s infinite;
	}
	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.25); }
		50%       { box-shadow: 0 0 0 6px rgba(34,197,94,0.1); }
	}

	.hero h1 {
		font-size: clamp(3rem, 8vw, 5rem);
		font-weight: 700;
		line-height: 1.05;
		margin-bottom: 0.3em;
		color: var(--text);
	}
	.gradient-text {
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.subtitle {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--text);
		margin: 0 0 0.3em;
	}
	.tagline {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0 0 1.75em;
		letter-spacing: 0.04em;
	}
	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25em;
		margin-bottom: 2em;
		font-size: 0.83rem;
	}
	.hero-meta span,
	.hero-meta a {
		display: flex;
		align-items: center;
		gap: 0.4em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.hero-meta a:hover { color: var(--accent); text-decoration: none; }

	.hero-actions { display: flex; gap: 0.75em; flex-wrap: wrap; }
	.btn-primary {
		display: inline-block;
		background: linear-gradient(135deg, var(--accent), var(--accent2));
		color: #fff;
		padding: 0.7em 1.6em;
		border-radius: 10px;
		font-weight: 700;
		font-size: 0.9rem;
		text-decoration: none;
		box-shadow: 0 4px 20px var(--accent-glow);
		transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
	}
	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 28px var(--accent-glow);
		opacity: 0.95;
		text-decoration: none;
	}
	.btn-ghost {
		display: inline-block;
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border-card);
		padding: 0.7em 1.6em;
		border-radius: 10px;
		font-weight: 600;
		font-size: 0.9rem;
		text-decoration: none;
		transition: background 0.15s, border-color 0.15s;
	}
	.btn-ghost:hover {
		background: var(--bg-secondary);
		border-color: var(--accent);
		color: var(--accent);
		text-decoration: none;
	}

	/* PHOTO */
	.hero-photo-wrap {
		position: relative;
		flex-shrink: 0;
	}
	.photo-ring {
		width: 220px;
		height: 220px;
		border-radius: 50%;
		overflow: hidden;
		border: 3px solid transparent;
		background: linear-gradient(var(--bg), var(--bg)) padding-box,
		            linear-gradient(135deg, var(--accent), var(--accent2)) border-box;
		box-shadow: var(--shadow-lg);
		position: relative;
		z-index: 1;
	}
	.avatar {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}
	.photo-glow {
		position: absolute;
		inset: -20px;
		border-radius: 50%;
		background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
		z-index: 0;
		animation: glow-pulse 3s ease-in-out infinite;
	}
	@keyframes glow-pulse {
		0%, 100% { opacity: 0.6; transform: scale(1); }
		50%       { opacity: 1;   transform: scale(1.05); }
	}

	/* ── SHARED ── */
	.section { padding: 5em 2em; }
	.container { max-width: 1080px; margin: 0 auto; }

	.eyebrow {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		background: linear-gradient(135deg, var(--accent), var(--accent2));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0 0 0.4em;
	}
	.section-title {
		font-size: 2rem;
		font-weight: 700;
		color: var(--text);
		margin: 0 0 2em;
	}

	/* ── SUMMARY ── */
	.summary-section {
		background: var(--bg-secondary);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 3.5em 2em;
	}
	.summary {
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--text-muted);
		max-width: 780px;
		margin: 0;
	}
	.summary strong { color: var(--text); }

	/* ── TIMELINE ── */
	.timeline { display: flex; flex-direction: column; gap: 1.5em; }
	.job {
		display: flex;
		background: var(--bg-card);
		border: 1px solid var(--border-card);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--shadow-md);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.job:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-lg);
	}
	.job-accent {
		width: 4px;
		flex-shrink: 0;
		background: linear-gradient(180deg, var(--accent), var(--accent2));
	}
	.job-body { padding: 1.75em 2em; flex: 1; }
	.job-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1em;
		margin-bottom: 1em;
		flex-wrap: wrap;
	}
	.company { font-size: 1.1rem; margin: 0 0 0.15em; color: var(--text); }
	.role { font-size: 0.875rem; color: var(--text-muted); margin: 0; font-style: italic; }
	.job-meta { text-align: right; flex-shrink: 0; }
	.period {
		display: block;
		font-size: 0.82rem;
		font-weight: 700;
		background: linear-gradient(135deg, var(--accent), var(--accent2));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.location { display: block; font-size: 0.78rem; color: var(--text-faint); margin-top: 0.15em; }
	.job ul {
		margin: 0 0 1.25em;
		padding-left: 1.2em;
		font-size: 0.88rem;
		line-height: 1.75;
		color: var(--text-muted);
	}
	.job li { margin-bottom: 0.4em; }
	.tags { display: flex; flex-wrap: wrap; gap: 0.4em; }
	.tags span {
		background: var(--bg-secondary);
		color: var(--text-muted);
		border: 1px solid var(--border);
		padding: 0.2em 0.7em;
		border-radius: 999px;
		font-size: 0.73rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	/* ── SKILLS ── */
	.skills-section {
		background: var(--bg-secondary);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.25em;
	}
	.skill-group {
		background: var(--bg-card);
		border: 1px solid var(--border-card);
		border-radius: 14px;
		padding: 1.5em;
		box-shadow: var(--shadow-sm);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.skill-group:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}
	.skill-icon { font-size: 1.5rem; margin-bottom: 0.6em; }
	.skill-group h4 {
		margin: 0 0 0.75em;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
	}
	.skill-tags { display: flex; flex-wrap: wrap; gap: 0.4em; }
	.skill-tags span {
		background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(168,85,247,0.1));
		color: var(--accent);
		border: 1px solid var(--border);
		padding: 0.25em 0.7em;
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 500;
	}

	/* ── EDUCATION ── */
	.edu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.25em;
		margin-bottom: 2.5em;
	}
	.edu-card {
		background: var(--bg-card);
		border: 1px solid var(--border-card);
		border-radius: 14px;
		padding: 1.5em;
		box-shadow: var(--shadow-sm);
	}
	.edu-year {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		background: linear-gradient(135deg, var(--accent), var(--accent2));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 0.5em;
	}
	.edu-card h3 { font-size: 0.95rem; margin: 0 0 0.25em; color: var(--text); }
	.edu-card p { font-size: 0.85rem; color: var(--text-muted); margin: 0; }

	.languages h3 { font-size: 1rem; margin: 0 0 1em; color: var(--text-muted); font-weight: 600; }
	.lang-list { display: flex; flex-wrap: wrap; gap: 0.75em; }
	.lang-item {
		display: flex;
		align-items: center;
		gap: 0.6em;
		background: var(--bg-card);
		border: 1px solid var(--border-card);
