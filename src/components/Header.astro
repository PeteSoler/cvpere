---
---

<header>
	<nav>
		<div class="brand">
			<a href="/">Pere Soler</a>
			<span class="title">Full-Stack Software Developer</span>
		</div>
		<div class="nav-links">
			<a href="#experience">Experience</a>
			<a href="#skills">Skills</a>
			<a href="#education">Education</a>
			<a href="mailto:peree.sooler@gmail.com" class="cta">Contact</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 2em;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		box-shadow: 0 1px 0 rgba(var(--gray-light), 1);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1000px;
		margin: 0 auto;
		height: 60px;
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.brand a {
		font-weight: 700;
		font-size: 1rem;
		color: rgb(var(--black));
		text-decoration: none;
		line-height: 1.2;
	}
	.brand .title {
		font-size: 0.65rem;
		color: rgb(var(--gray));
		line-height: 1.2;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	.nav-links a {
		padding: 0.4em 0.75em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.85rem;
		border-radius: 6px;
		transition: background 0.15s;
	}
	.nav-links a:hover {
		background: rgb(var(--gray-light));
		color: rgb(var(--black));
	}
	.nav-links a.cta {
		background: var(--accent);
		color: white;
		font-weight: 600;
	}
	.nav-links a.cta:hover {
		background: var(--accent-dark);
		color: white;
	}
	@media (max-width: 600px) {
		.nav-links a:not(.cta) { display: none; }
		.brand .title { display: none; }
	}
</style>
